pipeline {
    agent any

    environment {
        DOCKER_HOST = 'tcp://localhost:2375'
        DOCKER_IMAGE = 'lab-ci-api'
        CONTAINER_NAME = 'lab-ci-api-container'
        HOST_PORT = '3001'
        CONTAINER_PORT = '3000'
        MAIL_TO = 'joaquinbrocal25@gmail.com'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Instalar dependencias') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build local') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Tests automatizados con Jest') {
            steps {
                bat 'npm test'
            }
        }

        stage('Construir imagen Docker') {
            steps {
                // Corrección: Uso de comillas dobles e interpolación nativa de Groovy
                bat "docker build -t ${env.DOCKER_IMAGE} ."
            }
        }

        stage('Desplegar en Docker') {
            steps {
                bat "docker rm -f ${env.CONTAINER_NAME} || echo No habia contenedor previo"
                bat "docker run -d --name ${env.CONTAINER_NAME} -p ${env.HOST_PORT}:${env.CONTAINER_PORT} ${env.DOCKER_IMAGE}"
            }
        }

        stage('Verificar despliegue') {
            steps {
                // Corrección: Separar los comandos y usar el 'sleep' nativo de Jenkins
                sleep time: 5, unit: 'SECONDS'
                bat 'docker ps -a'
                bat "docker logs ${env.CONTAINER_NAME}"
                bat "curl.exe -f http://localhost:${env.HOST_PORT}/health"
            }
        }
    }

    post {
        always {
            emailext(
                to: "${env.MAIL_TO}",
                // Corrección: Manejo de null si el pipeline crashea antes de asignar un estado
                subject: "[${currentBuild.currentResult ?: 'UNKNOWN'}] ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
                mimeType: 'text/html',
                attachLog: true, // Te recomiendo ponerlo en true para ver por qué falló desde el correo
                compressLog: false,
                body: """
                    <html>
                        <body>
                            <h2>Reporte de pipeline - LabCI-CD</h2>

                            <p><b>Proyecto:</b> ${env.JOB_NAME}</p>
                            <p><b>Build:</b> #${env.BUILD_NUMBER}</p>
                            <p><b>Resultado:</b> ${currentBuild.currentResult ?: 'UNKNOWN'}</p>
                            <p><b>URL de Jenkins:</b> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>

                            <hr>

                            <h3>Etapas del pipeline</h3>
                            <ul>
                                <li>Checkout del código desde GitHub</li>
                                <li>Instalación de dependencias con npm install</li>
                                <li>Build local con npm run build</li>
                                <li>Tests automatizados con npm test</li>
                                <li>Construcción de imagen Docker</li>
                                <li>Despliegue local en contenedor Docker</li>
                                <li>Verificación del endpoint /health</li>
                            </ul>

                            <hr>

                            <p>Si el resultado fue <b>SUCCESS</b>, la aplicación fue construida, testeada, dockerizada, desplegada y verificada correctamente.</p>
                            <p>Si el resultado fue <b>FAILURE</b>, revisa el log adjunto o la consola en Jenkins para identificar la etapa que falló.</p>
                        </body>
                    </html>
                """
            )
        }

        success {
            echo 'Pipeline finalizado correctamente. Se intentó enviar feedback por mail.'
        }

        failure {
            echo 'El pipeline fallo. Se intento enviar feedback por mail con el log adjunto.'
        }
    }
}